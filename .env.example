DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/dewereldvan
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
BASE_URL=https://dewereldvan.ai
EMAIL_BACKEND=console
# EMAIL_BACKEND options: console | resend | cloudflare
RESEND_API_KEY=
# Cloudflare Email Service (EMAIL_BACKEND=cloudflare) — token needs "Email Sending: Edit"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
EMAIL_FROM=dewereldvan.ai <noreply@dewereldvan.ai>
MAGIC_LINK_TTL_MIN=15
PENDING_EXPIRY_DAYS=14
ADMIN_EMAILS=richard@theuws.com
SESSION_MAX_AGE_SEC=1209600
CONSOLE_EMAIL_DIR=data/outbox
RATE_LIMIT_MAGIC_PER_HOUR=5
RATE_LIMIT_REGISTER_PER_HOUR=5
# cloudflared: operator supplies TUNNEL_TOKEN (NOT in repo)
TUNNEL_TOKEN=
