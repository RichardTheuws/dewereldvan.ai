DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/dewereldvan
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
BASE_URL=https://dewereldvan.ai
EMAIL_BACKEND=console
# EMAIL_BACKEND options: console | resend | cloudflare
RESEND_API_KEY=
# Cloudflare Email Service (EMAIL_BACKEND=cloudflare) — token needs "Email Sending: Edit"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
EMAIL_FROM=dewereldvan.ai <noreply@dewereldvan.ai>
MAGIC_LINK_TTL_MIN=15
PENDING_EXPIRY_DAYS=14
ADMIN_EMAILS=richard@theuws.com
SESSION_MAX_AGE_SEC=1209600
CONSOLE_EMAIL_DIR=data/outbox
RATE_LIMIT_MAGIC_PER_HOUR=5
RATE_LIMIT_REGISTER_PER_HOUR=5
# --- AI-native profielbouw (F1-F3) ---
# Anthropic SDK leest ANTHROPIC_API_KEY zelf uit env; laat leeg om enrichment uit te zetten.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# fal.ai cover-generatie; leeg => NoopImageGenerator (cover optioneel, profiel werkt zonder).
FAL_KEY=
AI_ENRICH_ENABLED=true
RATE_LIMIT_AI_ENRICH_PER_HOUR=10
# ImageGenerator-backend: fal | noop
AI_IMAGE_BACKEND=fal
# --- Profielfoto-upload (L1) ---
# Opslag-subdir onder het /app/data-volume (geserveerd door de app op UPLOAD_URL_PREFIX).
UPLOAD_DIR=data/uploads
UPLOAD_URL_PREFIX=/uploads
# Hard cap op de daadwerkelijke bytes (server-hervalidatie met Pillow).
MAX_UPLOAD_BYTES=6291456
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
PHOTO_OUTPUT_PX=512
RATE_LIMIT_PHOTO_PER_HOUR=12
# cloudflared: operator supplies TUNNEL_TOKEN (NOT in repo)
TUNNEL_TOKEN=
